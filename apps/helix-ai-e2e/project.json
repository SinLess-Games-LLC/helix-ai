{
  "name": "helix-ai-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/helix-ai-e2e/src",
  "targets": {
    "e2e": {
      "executor": "@nx/cypress:cypress",
      "options": {
        "cypressConfig": "apps/helix-ai-e2e/cypress.config.ts",
        "testingType": "e2e",
        "devServerTarget": "helix-ai:serve"
      },
      "configurations": {
        "production": {
          "devServerTarget": "helix-ai:serve:production"
        },
        "ci": {
          "devServerTarget": "helix-ai:serve-static"
        }
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "lintFilePatterns": ["apps/helix-ai-e2e/**/*.{js,ts}"]
      }
    }
  },
  "implicitDependencies": ["helix-ai"],
  "tags": []
}
