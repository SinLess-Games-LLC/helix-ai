{
  "name": "next-web",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/next-web",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/next:build",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/next-web"
      },
      "configurations": {
        "development": {
          "outputPath": "apps/next-web"
        },
        "production": {}
      },
      "dependsOn": [
        "build-custom-server"
      ]
    },
    "serve": {
      "executor": "@nx/next:server",
      "defaultConfiguration": "development",
      "options": {
        "buildTarget": "next-web:build",
        "dev": true,
        "customServerTarget": "next-web:serve-custom-server"
      },
      "configurations": {
        "development": {
          "buildTarget": "next-web:build:development",
          "dev": true,
          "customServerTarget": "next-web:serve-custom-server:development"
        },
        "production": {
          "buildTarget": "next-web:build:production",
          "dev": false,
          "customServerTarget": "next-web:serve-custom-server:production"
        }
      }
    },
    "export": {
      "executor": "@nx/next:export",
      "options": {
        "buildTarget": "next-web:build:production"
      }
    },
    "test": {
      "executor": "@nx/jest:jest",
      "outputs": [
        "{workspaceRoot}/coverage/{projectRoot}"
      ],
      "options": {
        "jestConfig": "apps/next-web/jest.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "lintFilePatterns": [
          "apps/next-web/**/*.{ts,tsx,js,jsx}"
        ]
      }
    },
    "build-custom-server": {
      "executor": "@nx/js:tsc",
      "defaultConfiguration": "production",
      "options": {
        "outputPath": "dist/apps/next-web",
        "main": "apps/next-web/server/main.ts",
        "tsConfig": "apps/next-web/tsconfig.server.json",
        "clean": false,
        "assets": []
      },
      "configurations": {
        "development": {},
        "production": {}
      }
    },
    "serve-custom-server": {
      "executor": "@nx/js:node",
      "defaultConfiguration": "production",
      "options": {
        "buildTarget": "next-web:build-custom-server"
      },
      "configurations": {
        "development": {
          "buildTarget": "next-web:build-custom-server:development"
        },
        "production": {
          "buildTarget": "next-web:build-custom-server:production"
        }
      }
    },
    "container": {
      "executor": "@nx-tools/nx-container:build",
      "dependsOn": [
        "build"
      ],
      "options": {
        "engine": "docker",
        "metadata": {
          "images": [
            "next-web"
          ],
          "load": true,
          "tags": [
            "type=schedule",
            "type=ref,event=branch",
            "type=ref,event=tag",
            "type=ref,event=pr",
            "type=sha,prefix=sha-"
          ]
        }
      }
    }
  },
  "tags": []
}
